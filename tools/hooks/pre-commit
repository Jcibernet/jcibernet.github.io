#!/usr/bin/env bash
#
# Pre-commit pipeline:
#   1. If styles.scss changed → recompile to styles.css
#   2. If any cache-busted asset changed → re-run cache-bust.py
# To bypass intentionally:  git commit --no-verify

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

STAGED="$(git diff --cached --name-only --diff-filter=ACMR)"

# ---- 1. Recompile SCSS if source changed ----
if echo "$STAGED" | grep -qE '^styles/.*\.scss$'; then
    echo "[pre-commit] compiling SCSS → CSS..."
    if [ -x "node_modules/.bin/sass" ]; then
        node_modules/.bin/sass --no-source-map --style=expanded \
            styles/styles.scss styles/styles.css
    else
        echo "[pre-commit] ERROR: sass not installed. Run 'npm install' first." >&2
        exit 1
    fi
    git add styles/styles.css
fi

# ---- 2. Cache-bust if any tracked static asset is staged (incl. just-compiled CSS) ----
if git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^(styles/styles\.css|app\.js|fonts/(poppins-[0-9]+|spacegrotesk-variable)\.woff2)$' \
    > /dev/null; then
    echo "[pre-commit] cache-busting static assets..."
    python3 tools/cache-bust.py

    git add index.html \
            es/index.html \
            styles/styles.css 2>/dev/null || true
fi
